            "aadAdminObjectId": {
              "type": "string",
              "metadata": {
                "description": "AAD admin object ID (deployer)"
              }
            },
            "aadAdminLogin": {
              "type": "string",
              "metadata": {
                "description": "AAD admin login (deployer UPN)"
              }
            }
          },
          "variables": {
            "serverName": "[format('{0}-sql-{1}', parameters('prefix'), parameters('uniqueSuffix'))]",
