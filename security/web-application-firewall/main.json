{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "languageVersion": "2.0",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "13581105626114276519"
    }
  },
  "parameters": {
    "prefix": {
      "type": "string",
      "defaultValue": "clickapp",
      "metadata": {
        "description": "Resource naming prefix"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "eastus2",
      "metadata": {
        "description": "Azure region for Log Analytics workspace"
      }
    },
    "swaHostname": {
      "type": "string",
      "metadata": {
        "description": "Static Web App default hostname"
      }
    },
    "functionAppHostname": {
      "type": "string",
      "metadata": {
        "description": "Function App default hostname"
      }
    }
  },
  "resources": {
    "logAnalytics": {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2023-09-01",
      "name": "[format('{0}-waf-law', parameters('prefix'))]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30
      }
    },
    "frontDoorRef": {
      "existing": true,
      "type": "Microsoft.Cdn/profiles",
      "apiVersion": "2024-02-01",
      "name": "[format('{0}-afd', parameters('prefix'))]",
      "dependsOn": [
        "frontDoor"
      ]
    },
    "diagnosticSettings": {
      "type": "Microsoft.Insights/diagnosticSettings",
      "apiVersion": "2021-05-01-preview",
      "scope": "[resourceId('Microsoft.Cdn/profiles', format('{0}-afd', parameters('prefix')))]",
      "name": "[format('{0}-afd-diagnostics', parameters('prefix'))]",
      "properties": {
        "workspaceId": "[resourceId('Microsoft.OperationalInsights/workspaces', format('{0}-waf-law', parameters('prefix')))]",
        "logs": [
          {
            "categoryGroup": "allLogs",
            "enabled": true,
            "retentionPolicy": {
              "enabled": true,
              "days": 30
            }
          }
        ],
        "metrics": [
          {
            "category": "AllMetrics",
            "enabled": true,
            "retentionPolicy": {
              "enabled": true,
              "days": 30
            }
          }
        ]
      },
      "dependsOn": [
        "frontDoor",
        "logAnalytics"
      ]
    },
    "wafPolicy": {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "waf-policy-deployment",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "prefix": {
            "value": "[parameters('prefix')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.41.2.15936",
              "templateHash": "9250047929906992017"
            }
          },
          "parameters": {
            "location": {
              "type": "string",
              "defaultValue": "global",
              "metadata": {
                "description": "Azure region — WAF policies are global for Front Door"
              }
            },
            "prefix": {
              "type": "string",
              "metadata": {
                "description": "Resource naming prefix"
              }
            }
          },
          "variables": {
            "wafPolicyName": "[replace(format('{0}WafPolicy', parameters('prefix')), '-', '')]"
          },
          "resources": [
            {
              "type": "Microsoft.Network/FrontDoorWebApplicationFirewallPolicies",
              "apiVersion": "2024-02-01",
              "name": "[variables('wafPolicyName')]",
              "location": "[parameters('location')]",
              "sku": {
                "name": "Premium_AzureFrontDoor"
              },
              "properties": {
                "policySettings": {
                  "enabledState": "Enabled",
                  "mode": "Prevention",
                  "requestBodyCheck": "Enabled",
                  "customBlockResponseStatusCode": 403,
                  "customBlockResponseBody": "[base64('{\"error\":\"Request blocked by WAF policy\"}')]"
                },
                "managedRules": {
                  "managedRuleSets": [
                    {
                      "ruleSetType": "Microsoft_DefaultRuleSet",
                      "ruleSetVersion": "2.1",
                      "ruleSetAction": "Block"
                    },
                    {
                      "ruleSetType": "Microsoft_BotManagerRuleSet",
                      "ruleSetVersion": "1.1"
                    }
                  ]
                },
                "customRules": {
                  "rules": [
                    {
                      "name": "RateLimitRule",
                      "priority": 100,
                      "enabledState": "Enabled",
                      "ruleType": "RateLimitRule",
                      "rateLimitThreshold": 1000,
                      "rateLimitDurationInMinutes": 1,
                      "action": "Block",
                      "matchConditions": [
                        {
                          "matchVariable": "RemoteAddr",
                          "operator": "IPMatch",
                          "negateCondition": true,
                          "matchValue": [
                            "10.0.0.0/8"
                          ]
                        }
                      ]
                    }
                  ]
                }
              }
            }
          ],
          "outputs": {
            "wafPolicyId": {
              "type": "string",
              "value": "[resourceId('Microsoft.Network/FrontDoorWebApplicationFirewallPolicies', variables('wafPolicyName'))]"
            },
            "wafPolicyName": {
              "type": "string",
              "value": "[variables('wafPolicyName')]"
            }
          }
        }
      }
    },
    "frontDoor": {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "front-door-deployment",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "prefix": {
            "value": "[parameters('prefix')]"
          },
          "wafPolicyId": {
            "value": "[reference('wafPolicy').outputs.wafPolicyId.value]"
          },
          "swaHostname": {
            "value": "[parameters('swaHostname')]"
          },
          "functionAppHostname": {
            "value": "[parameters('functionAppHostname')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.41.2.15936",
              "templateHash": "2658820740188694673"
            }
          },
          "parameters": {
            "prefix": {
              "type": "string",
              "metadata": {
                "description": "Resource naming prefix"
              }
            },
            "wafPolicyId": {
              "type": "string",
              "metadata": {
                "description": "WAF policy resource ID to associate with security policy"
              }
            },
            "swaHostname": {
              "type": "string",
              "metadata": {
                "description": "Static Web App default hostname (e.g. xxx.azurestaticapps.net)"
              }
            },
            "functionAppHostname": {
              "type": "string",
              "metadata": {
                "description": "Function App default hostname (e.g. xxx.azurewebsites.net)"
              }
            }
          },
          "variables": {
            "frontDoorName": "[format('{0}-afd', parameters('prefix'))]",
            "webOriginGroupName": "web-origin-group",
            "apiOriginGroupName": "api-origin-group",
            "webOriginName": "swa-origin",
            "apiOriginName": "func-origin",
            "webRouteName": "web-route",
            "apiRouteName": "api-route",
            "webEndpointName": "[format('{0}-web-ep', parameters('prefix'))]",
            "securityPolicyName": "waf-security-policy"
          },
          "resources": [
            {
              "type": "Microsoft.Cdn/profiles",
              "apiVersion": "2024-02-01",
              "name": "[variables('frontDoorName')]",
              "location": "global",
              "sku": {
                "name": "Premium_AzureFrontDoor"
              },
              "properties": {
                "originResponseTimeoutSeconds": 60
              }
            },
            {
              "type": "Microsoft.Cdn/profiles/afdEndpoints",
              "apiVersion": "2024-02-01",
              "name": "[format('{0}/{1}', variables('frontDoorName'), variables('webEndpointName'))]",
              "location": "global",
              "properties": {
                "enabledState": "Enabled"
              },
              "dependsOn": [
                "[resourceId('Microsoft.Cdn/profiles', variables('frontDoorName'))]"
              ]
            },
            {
              "type": "Microsoft.Cdn/profiles/originGroups",
              "apiVersion": "2024-02-01",
              "name": "[format('{0}/{1}', variables('frontDoorName'), variables('webOriginGroupName'))]",
              "properties": {
                "loadBalancingSettings": {
                  "sampleSize": 4,
                  "successfulSamplesRequired": 3,
                  "additionalLatencyInMilliseconds": 50
                },
                "healthProbeSettings": {
                  "probePath": "/",
                  "probeRequestType": "HEAD",
                  "probeProtocol": "Https",
                  "probeIntervalInSeconds": 30
                },
                "sessionAffinityState": "Disabled"
              },
              "dependsOn": [
                "[resourceId('Microsoft.Cdn/profiles', variables('frontDoorName'))]"
              ]
            },
            {
              "type": "Microsoft.Cdn/profiles/originGroups/origins",
              "apiVersion": "2024-02-01",
              "name": "[format('{0}/{1}/{2}', variables('frontDoorName'), variables('webOriginGroupName'), variables('webOriginName'))]",
              "properties": {
                "hostName": "[parameters('swaHostname')]",
                "httpPort": 80,
                "httpsPort": 443,
                "originHostHeader": "[parameters('swaHostname')]",
                "priority": 1,
                "weight": 1000,
                "enabledState": "Enabled",
                "enforceCertificateNameCheck": true
              },
              "dependsOn": [
                "[resourceId('Microsoft.Cdn/profiles/originGroups', variables('frontDoorName'), variables('webOriginGroupName'))]"
              ]
            },
            {
              "type": "Microsoft.Cdn/profiles/originGroups",
              "apiVersion": "2024-02-01",
              "name": "[format('{0}/{1}', variables('frontDoorName'), variables('apiOriginGroupName'))]",
              "properties": {
                "loadBalancingSettings": {
                  "sampleSize": 4,
                  "successfulSamplesRequired": 3,
                  "additionalLatencyInMilliseconds": 50
                },
                "healthProbeSettings": {
                  "probePath": "/api/health",
                  "probeRequestType": "GET",
                  "probeProtocol": "Https",
                  "probeIntervalInSeconds": 30
                },
                "sessionAffinityState": "Disabled"
              },
              "dependsOn": [
                "[resourceId('Microsoft.Cdn/profiles', variables('frontDoorName'))]"
              ]
            },
            {
              "type": "Microsoft.Cdn/profiles/originGroups/origins",
              "apiVersion": "2024-02-01",
              "name": "[format('{0}/{1}/{2}', variables('frontDoorName'), variables('apiOriginGroupName'), variables('apiOriginName'))]",
              "properties": {
                "hostName": "[parameters('functionAppHostname')]",
                "httpPort": 80,
                "httpsPort": 443,
                "originHostHeader": "[parameters('functionAppHostname')]",
                "priority": 1,
                "weight": 1000,
                "enabledState": "Enabled",
                "enforceCertificateNameCheck": true
              },
              "dependsOn": [
                "[resourceId('Microsoft.Cdn/profiles/originGroups', variables('frontDoorName'), variables('apiOriginGroupName'))]"
              ]
            },
            {
              "type": "Microsoft.Cdn/profiles/afdEndpoints/routes",
              "apiVersion": "2024-02-01",
              "name": "[format('{0}/{1}/{2}', variables('frontDoorName'), variables('webEndpointName'), variables('webRouteName'))]",
              "properties": {
                "originGroup": {
                  "id": "[resourceId('Microsoft.Cdn/profiles/originGroups', variables('frontDoorName'), variables('webOriginGroupName'))]"
                },
                "patternsToMatch": [
                  "/*"
                ],
                "supportedProtocols": [
                  "Http",
                  "Https"
                ],
                "httpsRedirect": "Enabled",
                "forwardingProtocol": "HttpsOnly",
                "linkToDefaultDomain": "Enabled",
                "enabledState": "Enabled"
              },
              "dependsOn": [
                "[resourceId('Microsoft.Cdn/profiles/afdEndpoints', variables('frontDoorName'), variables('webEndpointName'))]",
                "[resourceId('Microsoft.Cdn/profiles/originGroups/origins', variables('frontDoorName'), variables('webOriginGroupName'), variables('webOriginName'))]",
                "[resourceId('Microsoft.Cdn/profiles/originGroups', variables('frontDoorName'), variables('webOriginGroupName'))]"
              ]
            },
            {
              "type": "Microsoft.Cdn/profiles/afdEndpoints/routes",
              "apiVersion": "2024-02-01",
              "name": "[format('{0}/{1}/{2}', variables('frontDoorName'), variables('webEndpointName'), variables('apiRouteName'))]",
              "properties": {
                "originGroup": {
                  "id": "[resourceId('Microsoft.Cdn/profiles/originGroups', variables('frontDoorName'), variables('apiOriginGroupName'))]"
                },
                "patternsToMatch": [
                  "/api/*"
                ],
                "supportedProtocols": [
                  "Http",
                  "Https"
                ],
                "httpsRedirect": "Enabled",
                "forwardingProtocol": "HttpsOnly",
                "linkToDefaultDomain": "Enabled",
                "enabledState": "Enabled"
              },
              "dependsOn": [
                "[resourceId('Microsoft.Cdn/profiles/originGroups/origins', variables('frontDoorName'), variables('apiOriginGroupName'), variables('apiOriginName'))]",
                "[resourceId('Microsoft.Cdn/profiles/originGroups', variables('frontDoorName'), variables('apiOriginGroupName'))]",
                "[resourceId('Microsoft.Cdn/profiles/afdEndpoints', variables('frontDoorName'), variables('webEndpointName'))]",
                "[resourceId('Microsoft.Cdn/profiles/afdEndpoints/routes', variables('frontDoorName'), variables('webEndpointName'), variables('webRouteName'))]"
              ]
            },
            {
              "type": "Microsoft.Cdn/profiles/securityPolicies",
              "apiVersion": "2024-02-01",
              "name": "[format('{0}/{1}', variables('frontDoorName'), variables('securityPolicyName'))]",
              "properties": {
                "parameters": {
                  "type": "WebApplicationFirewall",
                  "wafPolicy": {
                    "id": "[parameters('wafPolicyId')]"
                  },
                  "associations": [
                    {
                      "domains": [
                        {
                          "id": "[resourceId('Microsoft.Cdn/profiles/afdEndpoints', variables('frontDoorName'), variables('webEndpointName'))]"
                        }
                      ],
                      "patternsToMatch": [
                        "/*"
                      ]
                    }
                  ]
                }
              },
              "dependsOn": [
                "[resourceId('Microsoft.Cdn/profiles/afdEndpoints/routes', variables('frontDoorName'), variables('webEndpointName'), variables('apiRouteName'))]",
                "[resourceId('Microsoft.Cdn/profiles/afdEndpoints', variables('frontDoorName'), variables('webEndpointName'))]",
                "[resourceId('Microsoft.Cdn/profiles', variables('frontDoorName'))]",
                "[resourceId('Microsoft.Cdn/profiles/afdEndpoints/routes', variables('frontDoorName'), variables('webEndpointName'), variables('webRouteName'))]"
              ]
            }
          ],
          "outputs": {
            "frontDoorId": {
              "type": "string",
              "value": "[resourceId('Microsoft.Cdn/profiles', variables('frontDoorName'))]"
            },
            "frontDoorName": {
              "type": "string",
              "value": "[variables('frontDoorName')]"
            },
            "endpointHostname": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.Cdn/profiles/afdEndpoints', variables('frontDoorName'), variables('webEndpointName')), '2024-02-01').hostName]"
            },
            "endpointName": {
              "type": "string",
              "value": "[variables('webEndpointName')]"
            }
          }
        }
      },
      "dependsOn": [
        "wafPolicy"
      ]
    }
  },
  "outputs": {
    "wafPolicyName": {
      "type": "string",
      "value": "[reference('wafPolicy').outputs.wafPolicyName.value]"
    },
    "frontDoorName": {
      "type": "string",
      "value": "[reference('frontDoor').outputs.frontDoorName.value]"
    },
    "frontDoorEndpoint": {
      "type": "string",
      "value": "[reference('frontDoor').outputs.endpointHostname.value]"
    },
    "logAnalyticsWorkspaceName": {
      "type": "string",
      "value": "[format('{0}-waf-law', parameters('prefix'))]"
    }
  }
}